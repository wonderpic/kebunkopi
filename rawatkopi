<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Talaga Hangsa KopiPlanPro</title>
<style>
  :root {
    --green-50:#f0faf0;--green-100:#d6f0d6;
    --green-500:#388e3c;--green-600:#2e7d32;
    --green-700:#1b5e20;--green-800:#145214;
    --amber-300:#ffd54f;
    --text-dark:#1a2e1a;--text-mid:#3a5a3a;--text-muted:#6a8a6a;
    --warning-bg:#fff3e0;--warning-border:#e65100;--warning-text:#bf360c;
    --card-bg:rgba(255,255,255,0.90);--card-border:rgba(46,125,50,0.18);
    --shadow:0 4px 24px rgba(27,94,32,0.10);--radius:16px;--radius-sm:10px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{
    font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;
    background:linear-gradient(160deg,#1b5e20 0%,#2e7d32 30%,#388e3c 60%,#558b2f 85%,#8d6e63 100%);
    min-height:100vh;display:flex;justify-content:center;align-items:flex-start;
  }
  .app-shell{width:100%;max-width:430px;min-height:100vh;display:flex;flex-direction:column;}

  /* HEADER */
  .app-header{
    background:linear-gradient(180deg,rgba(0,0,0,0.32) 0%,rgba(0,0,0,0.08) 100%);
    padding:40px 24px 28px;text-align:center;
  }
  .logo-wrap{
    width:72px;height:72px;background:rgba(255,255,255,0.15);
    border:2px solid rgba(255,255,255,0.35);border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    margin:0 auto 14px;font-size:32px;
  }
  .app-title{font-size:22px;font-weight:700;color:#fff;letter-spacing:0.3px;line-height:1.2;}
  .app-title span{color:var(--amber-300);}
  .app-subtitle{font-size:11px;color:rgba(255,255,255,0.72);margin-top:5px;letter-spacing:0.8px;text-transform:uppercase;}

  /* NAV */
  .nav-bar{
    background:rgba(255,255,255,0.97);display:flex;
    border-bottom:1px solid rgba(46,125,50,0.12);position:sticky;top:0;z-index:100;
  }
  .nav-btn{
    flex:1;padding:13px 4px 11px;background:none;border:none;cursor:pointer;
    font-family:inherit;font-size:10.5px;font-weight:500;color:var(--text-muted);
    display:flex;flex-direction:column;align-items:center;gap:4px;
    border-bottom:3px solid transparent;transition:all 0.2s;
  }
  .nav-btn .icon{font-size:20px;line-height:1;}
  .nav-btn.active{color:var(--green-600);border-bottom-color:var(--green-500);font-weight:700;}
  .nav-btn:hover:not(.active){color:var(--green-500);background:var(--green-50);}

  /* CONTENT */
  .content{flex:1;padding:16px 13px 80px;}
  .tab-panel{display:none;} .tab-panel.active{display:block;}

  .section-title{
    font-size:17px;font-weight:700;color:#fff;margin-bottom:13px;
    text-shadow:0 1px 4px rgba(0,0,0,0.3);display:flex;align-items:center;gap:8px;
  }
  .section-title::before{content:'';width:4px;height:20px;background:var(--amber-300);border-radius:2px;display:inline-block;}

  /* STATS */
  .stats-bar{display:flex;gap:8px;margin-bottom:14px;}
  .stat-chip{flex:1;background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.25);border-radius:10px;padding:10px 6px;text-align:center;}
  .stat-num{font-size:20px;font-weight:700;color:#fff;line-height:1;}
  .stat-lbl{font-size:9.5px;color:rgba(255,255,255,0.7);text-transform:uppercase;letter-spacing:0.3px;margin-top:3px;}

  /* CARD */
  .card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);padding:15px;margin-bottom:12px;box-shadow:var(--shadow);}
  .card-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:11px;}
  .card-title{font-size:14.5px;font-weight:700;color:var(--text-dark);}
  .badge{font-size:10px;font-weight:600;padding:3px 8px;border-radius:20px;letter-spacing:0.3px;text-transform:uppercase;display:inline-block;}
  .badge-arabika{background:#e8f5e9;color:#1b5e20;} .badge-robusta{background:#fbe9e7;color:#bf360c;}
  .badge-organik{background:#f1f8e9;color:#33691e;} .badge-kimia{background:#e3f2fd;color:#1565c0;}
  .badge-kemarau{background:#fff3e0;color:#e65100;} .badge-hujan{background:#e8eaf6;color:#283593;}
  .card-info{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
  .info-row{display:flex;flex-direction:column;gap:2px;}
  .info-label{color:var(--text-muted);font-size:10.5px;text-transform:uppercase;letter-spacing:0.4px;}
  .info-val{color:var(--text-dark);font-weight:500;font-size:13px;}
  .alert{
    background:var(--warning-bg);border:1px solid var(--warning-border);
    border-left:4px solid var(--warning-border);border-radius:var(--radius-sm);
    padding:9px 11px;font-size:12px;color:var(--warning-text);margin-top:10px;line-height:1.5;
  }
  .delete-btn{background:none;border:1px solid rgba(198,40,40,0.3);color:#c62828;border-radius:8px;padding:5px 10px;font-size:11px;cursor:pointer;font-family:inherit;}
  .delete-btn:hover{background:#ffebee;}

  /* SCHEDULE */
  .sched-filter{display:flex;gap:6px;margin-bottom:12px;overflow-x:auto;padding-bottom:4px;}
  .filter-chip{
    background:rgba(255,255,255,0.18);border:1px solid rgba(255,255,255,0.3);
    color:rgba(255,255,255,0.85);border-radius:20px;padding:5px 12px;
    font-size:11px;font-weight:500;cursor:pointer;white-space:nowrap;font-family:inherit;
  }
  .filter-chip.active{background:rgba(255,255,255,0.92);color:var(--green-700);font-weight:700;}
  .schedule-item{
    background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius-sm);
    padding:12px 13px;margin-bottom:9px;box-shadow:0 2px 10px rgba(27,94,32,0.07);
    display:flex;align-items:center;gap:11px;position:relative;overflow:hidden;
  }
  .schedule-item::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;}
  .type-pupuk::before{background:#558b2f;} .type-pangkas::before{background:#00838f;}
  .type-panen::before{background:#e65100;} .type-siram::before{background:#1565c0;}
  .type-drainase::before{background:#6a1b9a;} .type-gulma::before{background:#4e342e;}
  .type-wiwilan::before{background:#00695c;}
  .sched-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0;}
  .type-pupuk .sched-icon{background:#f1f8e9;} .type-pangkas .sched-icon{background:#e0f7fa;}
  .type-panen .sched-icon{background:#fff3e0;} .type-siram .sched-icon{background:#e3f2fd;}
  .type-drainase .sched-icon{background:#f3e5f5;} .type-gulma .sched-icon{background:#efebe9;}
  .type-wiwilan .sched-icon{background:#e0f2f1;}
  .sched-body{flex:1;min-width:0;}
  .sched-task{font-size:13px;font-weight:600;color:var(--text-dark);margin-bottom:2px;}
  .sched-block{font-size:11px;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .sched-date{text-align:right;flex-shrink:0;}
  .sched-date-main{font-size:12.5px;font-weight:600;color:var(--green-600);}
  .sched-date-rel{font-size:10px;color:var(--text-muted);margin-top:2px;}
  .overdue{color:#c62828 !important;}

  /* SOURCE NOTE */
  .source-note{
    background:rgba(255,255,255,0.13);border:1px solid rgba(255,255,255,0.22);
    border-radius:10px;padding:10px 13px;margin-bottom:13px;
    font-size:11px;color:rgba(255,255,255,0.78);line-height:1.6;
  }
  .source-note strong{color:rgba(255,255,255,0.95);}

  /* FORM */
  .form-card{background:var(--card-bg);border:1px solid var(--card-border);border-radius:var(--radius);padding:18px 15px;box-shadow:var(--shadow);}
  .form-group{margin-bottom:14px;}
  .form-label{display:block;font-size:11px;font-weight:700;color:var(--text-mid);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;}
  .form-input{
    width:100%;padding:11px 12px;border:1.5px solid rgba(46,125,50,0.22);
    border-radius:var(--radius-sm);font-family:inherit;font-size:14px;color:var(--text-dark);
    background:#fff;outline:none;transition:border-color 0.15s;
  }
  .form-input:focus{border-color:var(--green-500);box-shadow:0 0 0 3px rgba(56,142,60,0.12);}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  .toggle-group{display:flex;gap:8px;}
  .toggle-opt{
    flex:1;padding:10px 5px;border:1.5px solid rgba(46,125,50,0.22);
    border-radius:var(--radius-sm);text-align:center;font-size:12.5px;font-weight:500;
    color:var(--text-mid);cursor:pointer;background:#fff;transition:all 0.15s;user-select:none;
  }
  .toggle-opt.selected{border-color:var(--green-600);background:var(--green-50);color:var(--green-700);font-weight:700;}
  .submit-btn{
    width:100%;padding:14px;background:linear-gradient(135deg,#2e7d32,#388e3c);
    color:#fff;border:none;border-radius:var(--radius-sm);font-family:inherit;
    font-size:15px;font-weight:700;cursor:pointer;margin-top:6px;
    display:flex;align-items:center;justify-content:center;gap:8px;
  }
  .submit-btn:active{transform:scale(0.98);}

  /* EMPTY */
  .empty-state{text-align:center;padding:48px 24px;color:rgba(255,255,255,0.6);}
  .empty-state .empty-icon{font-size:52px;margin-bottom:14px;}
  .empty-state p{font-size:14px;line-height:1.7;}

  /* TOAST */
  .toast{
    position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(40px);
    background:#1b5e20;color:#fff;padding:12px 20px;border-radius:24px;font-size:13px;
    font-weight:600;box-shadow:0 4px 20px rgba(0,0,0,0.25);opacity:0;
    transition:all 0.3s ease;z-index:999;white-space:nowrap;pointer-events:none;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>
<div class="app-shell">

  <div class="app-header">
    <div class="logo-wrap">☕</div>
    <div class="app-title">Talaga Hangsa <span>KopiPlanPro</span></div>
    <div class="app-subtitle">Asisten Digital Perawatan Kebun Kopi</div>
  </div>

  <nav class="nav-bar">
    <button class="nav-btn active" data-tab="kebun" onclick="switchTab('kebun')">
      <span class="icon">🏡</span>Data Kebun
    </button>
    <button class="nav-btn" data-tab="jadwal" onclick="switchTab('jadwal')">
      <span class="icon">📅</span>Jadwal Kerja
    </button>
    <button class="nav-btn" data-tab="tambah" onclick="switchTab('tambah')">
      <span class="icon">➕</span>Tambah Blok
    </button>
  </nav>

  <div class="content">

    <!-- TAB: DATA KEBUN -->
    <div id="tab-kebun" class="tab-panel active">
      <div class="stats-bar" id="statsBar"></div>
      <div class="section-title">Blok Kebun Aktif</div>
      <div id="kebunList"></div>
    </div>

    <!-- TAB: JADWAL KERJA -->
    <div id="tab-jadwal" class="tab-panel">
      <div class="section-title">Jadwal Kerja Terdekat</div>
      <div class="source-note">
        <strong>📚 Basis data ilmiah:</strong> Puslitkoka, BBPP Lembang Kementan, GAP Kopi Kementan RI, cybex.pertanian.go.id, repository.pertanian.go.id
      </div>
      <div class="sched-filter">
        <button class="filter-chip active" onclick="filterSchedule('semua',this)">Semua</button>
        <button class="filter-chip" onclick="filterSchedule('pupuk',this)">🌿 Pupuk</button>
        <button class="filter-chip" onclick="filterSchedule('siram',this)">💧 Siram</button>
        <button class="filter-chip" onclick="filterSchedule('gulma',this)">🌾 Gulma</button>
        <button class="filter-chip" onclick="filterSchedule('pangkas',this)">✂️ Pangkas</button>
        <button class="filter-chip" onclick="filterSchedule('panen',this)">☕ Panen</button>
      </div>
      <div id="jadwalList"></div>
    </div>

    <!-- TAB: TAMBAH BLOK -->
    <div id="tab-tambah" class="tab-panel">
      <div class="section-title">Tambah Blok Baru</div>
      <div class="form-card">
        <div class="form-group">
          <label class="form-label">Nama Blok</label>
          <input class="form-input" id="f_nama" type="text" placeholder="cth: Blok Utara A">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Lokasi (Kota)</label>
            <input class="form-input" id="f_lokasi" type="text" placeholder="cth: Bandung">
          </div>
          <div class="form-group">
            <label class="form-label">Ketinggian (mdpl)</label>
            <input class="form-input" id="f_mdpl" type="number" placeholder="1200" min="0" max="3000">
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Varietas</label>
          <div class="toggle-group">
            <div class="toggle-opt selected" data-field="varietas" data-val="Arabika" onclick="selectToggle(this)">🌿 Arabika</div>
            <div class="toggle-opt" data-field="varietas" data-val="Robusta" onclick="selectToggle(this)">🌱 Robusta</div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Metode Pupuk</label>
          <div class="toggle-group">
            <div class="toggle-opt selected" data-field="pupuk" data-val="Organik" onclick="selectToggle(this)">🍃 Organik</div>
            <div class="toggle-opt" data-field="pupuk" data-val="Kimia" onclick="selectToggle(this)">⚗️ Kimia</div>
          </div>
        </div>
        <div class="form-group">
          <label class="form-label">Kondisi Cuaca</label>
          <div class="toggle-group">
            <div class="toggle-opt selected" data-field="cuaca" data-val="Kemarau" onclick="selectToggle(this)">☀️ Kemarau</div>
            <div class="toggle-opt" data-field="cuaca" data-val="Hujan" onclick="selectToggle(this)">🌧️ Hujan</div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Tanggal Tanam</label>
            <input class="form-input" id="f_tanggal" type="date">
          </div>
          <div class="form-group">
            <label class="form-label">Jumlah Pohon</label>
            <input class="form-input" id="f_pohon" type="number" placeholder="150" min="1">
          </div>
        </div>
        <button class="submit-btn" onclick="tambahBlok()">➕ Simpan Blok</button>
      </div>
    </div>

  </div>
</div>
<div class="toast" id="toast"></div>

<script>
const STORAGE_KEY = 'kopiplanpro_v3';
let bloks = [];
try { bloks = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) { bloks = []; }
let currentFilter = 'semua';
const formState = { varietas:'Arabika', pupuk:'Organik', cuaca:'Kemarau' };

function selectToggle(el) {
  const field = el.dataset.field, val = el.dataset.val;
  formState[field] = val;
  document.querySelectorAll(`.toggle-opt[data-field="${field}"]`).forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}

function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
  if (tab === 'kebun') renderKebun();
  if (tab === 'jadwal') renderJadwal();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

function addDays(dateStr, days) {
  const d = new Date(dateStr);
  d.setDate(d.getDate() + days);
  return d;
}
function formatDate(d) {
  return d.toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' });
}
function relativeDay(d) {
  const today = new Date(); today.setHours(0,0,0,0);
  const diff = Math.round((d - today) / 86400000);
  if (diff < 0) return Math.abs(diff) + ' hari lalu';
  if (diff === 0) return 'Hari ini!';
  if (diff === 1) return 'Besok';
  return diff + ' hari lagi';
}

function generateTasks(blok) {
  const tasks = [];
  const add = (label, daysArr, type, icon) => {
    daysArr.forEach(d => tasks.push({
      blokId:blok.id, blokNama:blok.nama, lokasi:blok.lokasi,
      task:label, targetDate:addDays(blok.tanggal, d), type, icon
    }));
  };

  // PEMUPUKAN — 2x setahun (~180 hari), mulai hari ke-60
  // Sumber: Puslitkoka, BBPP Lembang, GAP Kementan
  const labelPupuk = blok.pupuk === 'Organik'
    ? 'Pemupukan Organik (10–20 kg/pohon)'
    : 'Pemupukan Anorganik (Urea+SP36+KCl)';
  const daysPupuk = [];
  for (let d = 60; d <= 1825; d += 180) daysPupuk.push(d);
  add(labelPupuk, daysPupuk, 'pupuk', blok.pupuk === 'Organik' ? '🍃' : '⚗️');

  // VARIETAS
  if (blok.varietas === 'Arabika') {
    // Pangkas pembentukan: umur 1–2 tahun | Sumber: BBPP Lembang, cybex.pertanian.go.id
    add('Pangkas Pembentukan Arabika', [365, 540], 'pangkas', '✂️');
    // Pangkas produksi: tiap tahun setelah panen | Sumber: Puslitkoka 2010
    add('Pangkas Produksi/Lewat Panen', [1460, 1825], 'pangkas', '✂️');
    // Panen: umur 3 tahun | Sumber: Puslitkoka, repository.pertanian.go.id
    add('Panen Perdana Arabika', [1095], 'panen', '☕');
    add('Panen Arabika Tahun ke-4', [1460], 'panen', '☕');
  } else {
    // Wiwilan perdana: bulan ke-6 | Sumber: Dinas Pertanian Buleleng
    add('Wiwilan Perdana Robusta', [180], 'wiwilan', '🌿');
    add('Wiwilan Robusta Tahunan', [545, 910], 'wiwilan', '🌿');
    // Panen: umur 2,5 tahun | Sumber: Puslitkoka, alamtani.com, cybex.pertanian.go.id
    add('Panen Perdana Robusta', [900], 'panen', '☕');
    add('Panen Robusta Tahun ke-4', [1265], 'panen', '☕');
  }

  // CUACA
  if (blok.cuaca === 'Kemarau') {
    // Siram tiap 3 hari | Sumber: Puslitkoka, Kepmentan No.27/2021
    add('Penyiraman Rutin', [3,6,9,12,15,18,21,24,27,30], 'siram', '💧');
  } else {
    // Drainase tiap 7 hari | Sumber: GAP Kementan
    add('Periksa Saluran Drainase', [7,14,21,28], 'drainase', '🌊');
  }
  // Gulma tiap 14 hari (semua kondisi) | Sumber: agribisnis.uma.ac.id, Puslitkoka
  add('Penyiangan Gulma', [14,28,42,56,70,84], 'gulma', '🌾');

  return tasks;
}

function getAlerts(blok) {
  const alerts = [], mdpl = parseInt(blok.mdpl);
  if (blok.varietas === 'Arabika' && mdpl < 1000)
    alerts.push('⚠️ Arabika < 1.000 mdpl: risiko karat daun (Hemileia vastatrix). Gunakan varietas tahan karat atau fungisida preventif. (Puslitkoka 2010)');
  if (blok.varietas === 'Robusta' && mdpl > 900)
    alerts.push('⚠️ Robusta > 900 mdpl: di luar zona optimal (400–900 mdpl). Berisiko pembungaan lambat & produksi tidak maksimal. (BBPP Lembang, Kementan)');
  return alerts;
}

function renderKebun() {
  const total = bloks.length;
  const arabika = bloks.filter(b => b.varietas==='Arabika').length;
  const robusta = bloks.filter(b => b.varietas==='Robusta').length;
  const pohon = bloks.reduce((s,b) => s + parseInt(b.pohon||0), 0);

  document.getElementById('statsBar').innerHTML =
    `<div class="stat-chip"><div class="stat-num">${total}</div><div class="stat-lbl">Blok</div></div>
     <div class="stat-chip"><div class="stat-num">${arabika}</div><div class="stat-lbl">Arabika</div></div>
     <div class="stat-chip"><div class="stat-num">${robusta}</div><div class="stat-lbl">Robusta</div></div>
     <div class="stat-chip"><div class="stat-num">${pohon.toLocaleString('id-ID')}</div><div class="stat-lbl">Pohon</div></div>`;

  if (!bloks.length) {
    document.getElementById('kebunList').innerHTML =
      `<div class="empty-state"><div class="empty-icon">🌱</div><p>Belum ada blok kebun.<br>Tambahkan blok pertama Anda<br>melalui tab <strong>Tambah Blok</strong>!</p></div>`;
    return;
  }

  document.getElementById('kebunList').innerHTML = bloks.map(blok => {
    const alerts = getAlerts(blok);
    return `<div class="card">
      <div class="card-header">
        <div class="card-title">🏡 ${blok.nama}</div>
        <button class="delete-btn" onclick="hapusBlok('${blok.id}')">🗑️ Hapus</button>
      </div>
      <div class="card-info">
        <div class="info-row"><span class="info-label">Lokasi</span><span class="info-val">📍 ${blok.lokasi}</span></div>
        <div class="info-row"><span class="info-label">Ketinggian</span><span class="info-val">⛰️ ${parseInt(blok.mdpl).toLocaleString('id-ID')} mdpl</span></div>
        <div class="info-row"><span class="info-label">Varietas</span><span class="badge badge-${blok.varietas.toLowerCase()}">${blok.varietas}</span></div>
        <div class="info-row"><span class="info-label">Pupuk</span><span class="badge badge-${blok.pupuk.toLowerCase()}">${blok.pupuk}</span></div>
        <div class="info-row"><span class="info-label">Cuaca</span><span class="badge badge-${blok.cuaca.toLowerCase()}">${blok.cuaca}</span></div>
        <div class="info-row"><span class="info-label">Tanam</span><span class="info-val">${new Date(blok.tanggal).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'})}</span></div>
        <div class="info-row"><span class="info-label">Pohon</span><span class="info-val">🌱 ${parseInt(blok.pohon).toLocaleString('id-ID')} pohon</span></div>
      </div>
      ${alerts.map(a => `<div class="alert">${a}</div>`).join('')}
    </div>`;
  }).join('');
}

function renderJadwal() {
  let all = [];
  bloks.forEach(b => all = all.concat(generateTasks(b)));
  all.sort((a,b) => a.targetDate - b.targetDate);
  const filtered = currentFilter === 'semua' ? all : all.filter(t => t.type === currentFilter);

  if (!filtered.length) {
    document.getElementById('jadwalList').innerHTML =
      `<div class="empty-state"><div class="empty-icon">📅</div><p>${!bloks.length ? 'Tambahkan blok kebun<br>untuk melihat jadwal kerja.' : 'Tidak ada jadwal untuk filter ini.'}</p></div>`;
    return;
  }

  document.getElementById('jadwalList').innerHTML = filtered.map(t => {
    const rel = relativeDay(t.targetDate);
    const od = t.targetDate < new Date();
    return `<div class="schedule-item type-${t.type}">
      <div class="sched-icon">${t.icon}</div>
      <div class="sched-body">
        <div class="sched-task">${t.task}</div>
        <div class="sched-block">📍 ${t.blokNama} — ${t.lokasi}</div>
      </div>
      <div class="sched-date">
        <div class="sched-date-main ${od?'overdue':''}">${formatDate(t.targetDate)}</div>
        <div class="sched-date-rel ${od?'overdue':''}">${rel}</div>
      </div>
    </div>`;
  }).join('');
}

function filterSchedule(type, btn) {
  currentFilter = type;
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  renderJadwal();
}

function tambahBlok() {
  const nama = document.getElementById('f_nama').value.trim();
  const lokasi = document.getElementById('f_lokasi').value.trim();
  const mdpl = document.getElementById('f_mdpl').value;
  const tanggal = document.getElementById('f_tanggal').value;
  const pohon = document.getElementById('f_pohon').value;
  if (!nama||!lokasi||!mdpl||!tanggal||!pohon) { showToast('⚠️ Harap isi semua kolom!'); return; }

  bloks.push({ id:Date.now().toString(), nama, lokasi, mdpl,
    varietas:formState.varietas, pupuk:formState.pupuk, cuaca:formState.cuaca, tanggal, pohon });
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(bloks)); } catch(e) {}

  ['f_nama','f_lokasi','f_mdpl','f_tanggal','f_pohon'].forEach(id => document.getElementById(id).value='');
  formState.varietas='Arabika'; formState.pupuk='Organik'; formState.cuaca='Kemarau';
  document.querySelectorAll('.toggle-opt').forEach(o =>
    o.classList.toggle('selected', o.dataset.val === formState[o.dataset.field]));

  showToast('✅ Blok "' + nama + '" berhasil ditambahkan!');
  switchTab('kebun');
}

function hapusBlok(id) {
  if (!confirm('Hapus blok ini beserta seluruh jadwalnya?')) return;
  bloks = bloks.filter(b => b.id !== id);
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(bloks)); } catch(e) {}
  renderKebun();
  showToast('🗑️ Blok berhasil dihapus.');
}

// Init
document.getElementById('f_tanggal').value = new Date().toISOString().split('T')[0];
renderKebun();
</script>
</body>
</html>
