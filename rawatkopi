          </div>
        </div>
        <button class="submit-btn" onclick="tambahBlok()">
          <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Simpan Blok
        </button>
      </div>
    </div>

  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const STORAGE_KEY = 'kopiplanpro_v3';
let bloks = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
let currentFilter = 'semua';
const formState = { varietas:'Arabika', pupuk:'Organik', cuaca:'Kemarau' };

function selectToggle(el) {
  const field = el.dataset.field, val = el.dataset.val;
  formState[field] = val;
  document.querySelectorAll(`.toggle-opt[data-field="${field}"]`).forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
}

function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-' + tab).classList.add('active');
  document.querySelector(`[data-tab="${tab}"]`).classList.add('active');
  if (tab === 'kebun') renderKebun();
  if (tab === 'jadwal') renderJadwal();
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

function addDays(dateStr, days) {
  const d = new Date(dateStr);
  d.setDate(d.getDate() + days);
  return d;
}

function formatDate(d) {
  return d.toLocaleDateString('id-ID', { day:'2-digit', month:'short', year:'numeric' });
}

function relativeDay(d) {
  const today = new Date(); today.setHours(0,0,0,0);
  const diff = Math.round((d - today) / 86400000);
  if (diff < 0) return `${Math.abs(diff)} hari lalu`;
  if (diff === 0) return 'Hari ini!';
  if (diff === 1) return 'Besok';
  return `${diff} hari lagi`;
}

/*
 * JADWAL BERDASARKAN DATA ILMIAH RESMI
 * ─────────────────────────────────────────────────────────────
 * Sumber: Puslitkoka, BBPP Lembang Kementan, GAP Kopi Kementan RI,
 *         cybex.pertanian.go.id, repository.pertanian.go.id
 *
 * PEMUPUKAN
 *   - Organik (pupuk kandang/kompos): 10-20 kg/pohon/tahun
 *     Diberikan 2× setahun → interval ~180 hari
 *     (Sumber: BBPP Lembang / GAP Kopi Kementan)
 *   - Anorganik/Kimia (Urea+SP36+KCl): 2–4× setahun
 *     Awal & akhir musim hujan → interval ~180 hari
 *     (Sumber: cybex.pertanian.go.id, Puslitkoka, Gokomodo/Kementan)
 *     Pertama pada umur ~2 bulan (60 hari) setelah tanam
 *
 * PEMANGKASAN ARABIKA (sistem batang tunggal)
 *   - Pangkas Pembentukan: umur 1–2 tahun (hari ke-365 & ke-540)
 *   - Pangkas Produksi/Lewat Panen: tiap tahun setelah panen pertama
 *     (mulai hari ke-1095+365 = ke-1460, tiap 365 hari)
 *   (Sumber: BBPP Lembang, cybex.pertanian.go.id, Puslitkoka 2010)
 *
 * PANGKAS WIWILAN ROBUSTA
 *   - Wiwilan pertama: ~bulan ke-6 (180 hari) untuk membuang tunas liar
 *   - Pemangkasan produksi: setelah panen pertama (hari ke-900), tiap tahun
 *   (Sumber: Dinas Pertanian Buleleng, cybex.pertanian.go.id)
 *
 * PANEN
 *   - Robusta: mulai umur 2,5 tahun = hari ke-900
 *     (konsensus multi-sumber: Puslitkoka, alamtani.com, gramedia.com)
 *   - Arabika: mulai umur 3 tahun = hari ke-1095
 *     (konsensus multi-sumber: Puslitkoka, cybex.pertanian.go.id)
 *
 * PENYIRAMAN KEMARAU
 *   - Bibit/tanaman muda: setiap 3 hari (Puslitkoka/Pedoman Robusta Lampung)
 *   - Diulang setiap 3 hari untuk 6 siklus pertama (18 hari pertama)
 *
 * PENYIANGAN GULMA (Musim Hujan & Kemarau)
 *   - Setiap 2 minggu/14 hari
 *   (Sumber: agribisnis.uma.ac.id, Puslitkoka)
 *
 * DRAINASE (Musim Hujan)
 *   - Pantau & bersihkan saluran setiap 7 hari
 *   (Sumber: praktik GAP Kementan untuk lahan kopi)
 *
 * SMART ALERT GEOGRAFI
 *   - Arabika < 1000 mdpl: risiko karat daun (Hemileia vastatrix)
 *     (Sumber: Puslitkoka 2010, repository.pertanian.go.id hal.3)
 *   - Robusta > 900 mdpl: di luar zona optimal (optimal 400-900 mdpl)
 *     risiko pembungaan lambat
 *     (Sumber: BBPP Lembang, cybex.pertanian.go.id)
 */

function generateTasks(blok) {
  const tasks = [];
  const plant = blok.tanggal;

  const add = (label, daysArr, type, icon) => {
    daysArr.forEach(d => {
      tasks.push({
        blokId: blok.id,
        blokNama: blok.nama,
        lokasi: blok.lokasi,
        task: label,
        targetDate: addDays(plant, d),
        type, icon
      });
    });
  };

  // ── PEMUPUKAN ──────────────────────────────────────────────
  // Pertama pada hari ke-60 (umur ~2 bulan), lalu tiap 180 hari
  // Selama 5 tahun (1825 hari) → maksimal 10 sesi
  if (blok.pupuk === 'Organik') {
    const label = 'Pemupukan Organik (10–20 kg/pohon)';
    const days = [];
    for (let d = 60; d <= 1825; d += 180) days.push(d);
    add(label, days, 'pupuk', '🌿');
  } else {
    const label = 'Pemupukan Anorganik (Urea+SP36+KCl)';
    const days = [];
    for (let d = 60; d <= 1825; d += 180) days.push(d);
    add(label, days, 'pupuk', '⚗️');
  }

  // ── VARIETAS-SPESIFIK ─────────────────────────────────────
  if (blok.varietas === 'Arabika') {
    // Pangkas pembentukan: tahun ke-1 dan ke-2 (hari ke-365, ke-540)
    add('Pangkas Pembentukan Arabika', [365, 540], 'pangkas', '✂️');
    // Pangkas produksi: tiap tahun setelah panen pertama (mulai hari ke-1095+365)
    add('Pangkas Produksi/Lewat Panen', [1460, 1825], 'pangkas', '✂️');
    // Panen pertama: umur 3 tahun = hari ke-1095
    add('Panen Perdana Arabika', [1095], 'panen', '☕');
    add('Panen Arabika Tahun ke-4', [1460], 'panen', '☕');
  } else {
    // Wiwilan pertama: bulan ke-6 untuk buang tunas liar
    add('Wiwilan Perdana Robusta', [180], 'wiwilan', '🌿');
    // Wiwilan tahunan berikutnya
    add('Wiwilan Robusta Tahunan', [545, 910], 'wiwilan', '🌿');
    // Panen pertama: umur 2,5 tahun = hari ke-900
    add('Panen Perdana Robusta', [900], 'panen', '☕');
    add('Panen Robusta Tahun ke-4', [1265], 'panen', '☕');
  }

  // ── CUACA ──────────────────────────────────────────────────
  if (blok.cuaca === 'Kemarau') {
    // Penyiraman setiap 3 hari untuk 6 siklus awal (18 hari pertama)
    add('Penyiraman Rutin', [3, 6, 9, 12, 15, 18], 'siram', '💧');
    // Penyiraman lanjutan tiap 3 hari, bulan pertama lanjut
    add('Penyiraman Lanjutan', [21, 24, 27, 30], 'siram', '💧');
  } else {
    // Musim hujan: pantau drainase tiap 7 hari (bulan pertama)
    add('Periksa Saluran Drainase', [7, 14, 21, 28], 'drainase', '🌊');
    // Penyiangan gulma setiap 14 hari
    add('Penyiangan Gulma', [14, 28, 42, 56, 70, 84], 'gulma', '🌾');
  }
  // Gulma juga wajib pada kemarau setiap 14 hari (pertumbuhan lebih lambat tapi tetap ada)
  if (blok.cuaca === 'Kemarau') {
    add('Penyiangan Gulma', [14, 28, 42, 56, 70, 84], 'gulma', '🌾');
  }

  return tasks;
}

function getAlerts(blok) {
  const alerts = [];
  const mdpl = parseInt(blok.mdpl);
  if (blok.varietas === 'Arabika' && mdpl < 1000) {
    alerts.push('⚠️ Arabika < 1.000 mdpl: risiko tinggi karat daun (Hemileia vastatrix). Pertimbangkan varietas tahan karat atau fungisida preventif. (Sumber: Puslitkoka 2010)');
  }
  if (blok.varietas === 'Robusta' && mdpl > 900) {
    alerts.push('⚠️ Robusta > 900 mdpl: di luar zona optimal (400–900 mdpl). Berisiko pembungaan lambat & produksi tidak maksimal. (Sumber: BBPP Lembang, Kementan)');
  }
  return alerts;
}

function renderKebun() {
  const total = bloks.length;
  const arabika = bloks.filter(b => b.varietas === 'Arabika').length;
  const robusta = bloks.filter(b => b.varietas === 'Robusta').length;
  const pohon = bloks.reduce((s, b) => s + parseInt(b.pohon || 0), 0);

  document.getElementById('statsBar').innerHTML = `
    <div class="stat-chip"><div class="stat-num">${total}</div><div class="stat-lbl">Blok</div></div>
    <div class="stat-chip"><div class="stat-num">${arabika}</div><div class="stat-lbl">Arabika</div></div>
    <div class="stat-chip"><div class="stat-num">${robusta}</div><div class="stat-lbl">Robusta</div></div>
    <div class="stat-chip"><div class="stat-num">${pohon.toLocaleString('id-ID')}</div><div class="stat-lbl">Pohon</div></div>
  `;

  if (bloks.length === 0) {
    document.getElementById('kebunList').innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24"><path d="M17 8C8 10 5.9 16.17 3.82 19.83M5.64 9.64C5.64 9.64 8.64 6.64 14 8C14 8 12 12 14 16M13.6 10.4C13.6 10.4 17 9 21 11"/><path d="M3 22C3 22 6 16 9 16C12 16 15 19 15 19"/></svg>
        <p>Belum ada blok kebun.<br>Tambahkan blok pertama Anda!</p>
      </div>`;
    return;
  }

  document.getElementById('kebunList').innerHTML = bloks.map(blok => {
    const alerts = getAlerts(blok);
    return `
    <div class="card">
      <div class="card-header">
        <div class="card-title">🏡 ${blok.nama}</div>
        <button class="delete-btn" onclick="hapusBlok('${blok.id}')">Hapus</button>
      </div>
      <div class="card-info">
        <div class="info-row"><span class="info-label">Lokasi</span><span class="info-val">📍 ${blok.lokasi}</span></div>
        <div class="info-row"><span class="info-label">Ketinggian</span><span class="info-val">⛰️ ${parseInt(blok.mdpl).toLocaleString('id-ID')} mdpl</span></div>
        <div class="info-row"><span class="info-label">Varietas</span><span class="badge badge-${blok.varietas.toLowerCase()}">${blok.varietas}</span></div>
        <div class="info-row"><span class="info-label">Pupuk</span><span class="badge badge-${blok.pupuk.toLowerCase()}">${blok.pupuk}</span></div>
        <div class="info-row"><span class="info-label">Cuaca</span><span class="badge badge-${blok.cuaca.toLowerCase()}">${blok.cuaca}</span></div>
        <div class="info-row"><span class="info-label">Tanam</span><span class="info-val">${new Date(blok.tanggal).toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'})}</span></div>
        <div class="info-row"><span class="info-label">Pohon</span><span class="info-val">🌱 ${parseInt(blok.pohon).toLocaleString('id-ID')} pohon</span></div>
      </div>
      ${alerts.map(a => `<div class="alert"><svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg><span>${a}</span></div>`).join('')}
    </div>`;
  }).join('');
}

function renderJadwal() {
  let allTasks = [];
  bloks.forEach(blok => allTasks = allTasks.concat(generateTasks(blok)));

  // Sort global by targetDate (asc)
  allTasks.sort((a, b) => a.targetDate - b.targetDate);

  const filtered = currentFilter === 'semua'
    ? allTasks
    : allTasks.filter(t => t.type === currentFilter);

  if (filtered.length === 0) {
    document.getElementById('jadwalList').innerHTML = `
      <div class="empty-state">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        <p>${bloks.length === 0 ? 'Tambahkan blok kebun untuk melihat jadwal kerja.' : 'Tidak ada jadwal untuk filter ini.'}</p>
      </div>`;
    return;
  }

  document.getElementById('jadwalList').innerHTML = filtered.map(t => {
    const rel = relativeDay(t.targetDate);
    const isOverdue = t.targetDate < new Date();
    return `
    <div class="schedule-item type-${t.type}">
      <div class="sched-icon">${t.icon}</div>
      <div class="sched-body">
        <div class="sched-task">${t.task}</div>
        <div class="sched-block">📍 ${t.blokNama} — ${t.lokasi}</div>
      </div>
      <div class="sched-date">
        <div class="sched-date-main ${isOverdue ? 'overdue' : ''}">${formatDate(t.targetDate)}</div>
        <div class="sched-date-rel ${isOverdue ? 'overdue' : ''}">${rel}</div>
      </div>
    </div>`;
  }).join('');
}

function filterSchedule(type, btn) {
  currentFilter = type;
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  renderJadwal();
}

function tambahBlok() {
  const nama = document.getElementById('f_nama').value.trim();
  const lokasi = document.getElementById('f_lokasi').value.trim();
  const mdpl = document.getElementById('f_mdpl').value;
  const tanggal = document.getElementById('f_tanggal').value;
  const pohon = document.getElementById('f_pohon').value;

  if (!nama || !lokasi || !mdpl || !tanggal || !pohon) {
    showToast('⚠️ Harap isi semua kolom!'); return;
  }

  const blok = { id: Date.now().toString(), nama, lokasi, mdpl, varietas: formState.varietas, pupuk: formState.pupuk, cuaca: formState.cuaca, tanggal, pohon };
  bloks.push(blok);
  localStorage.setItem(STORAGE_KEY, JSON.stringify(bloks));

  document.getElementById('f_nama').value = '';
  document.getElementById('f_lokasi').value = '';
  document.getElementById('f_mdpl').value = '';
  document.getElementById('f_tanggal').value = '';
  document.getElementById('f_pohon').value = '';
  formState.varietas = 'Arabika'; formState.pupuk = 'Organik'; formState.cuaca = 'Kemarau';
  document.querySelectorAll('.toggle-opt').forEach(o => o.classList.toggle('selected', o.dataset.val === formState[o.dataset.field]));

  showToast(`✅ Blok "${nama}" berhasil ditambahkan!`);
  switchTab('kebun');
}

function hapusBlok(id) {
  if (!confirm('Hapus blok ini beserta seluruh jadwalnya?')) return;
  bloks = bloks.filter(b => b.id !== id);
  localStorage.setItem(STORAGE_KEY, JSON.stringify(bloks));
  renderKebun();
  showToast('🗑️ Blok berhasil dihapus.');
}

document.getElementById('f_tanggal').value = new Date().toISOString().split('T')[0];
renderKebun();
</script>
</body>
